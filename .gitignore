# Dataset policy
# Keep large research data and generated curation artifacts local.
# Commit code, specs, docs, and tests; do not commit raw images, raw JSON batches,
# generated crops, partition manifests, operation logs, or dataset zip exports.
*.zip
batch_*/images/
batch_*/json/
batch_*/class_crops/
batch_*/curation/
